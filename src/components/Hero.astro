---
import { profile } from "../data/profile";
---

<section class="border-b border-cream-300 py-20 dark:border-white/10">
  <div class="grid gap-10 md:grid-cols-12 md:gap-12 lg:gap-16">
    <div class="md:col-span-7">
      {
        profile.availableForWork && (
          <span class="inline-flex items-center gap-2 text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500">
            <span class="size-1.5 rounded-full bg-brand-500" />
            Available for work · {profile.location}
          </span>
        )
      }
      <h1
        class="mt-6 text-4xl font-normal leading-[1.05] tracking-[-0.03em] sm:text-6xl md:text-6xl lg:text-7xl"
      >
        {profile.headline}<span class="text-brand-500">.</span>
      </h1>
      <p
        class="mt-6 max-w-3xl text-base/relaxed text-cream-700 dark:text-cream-500"
      >
        {profile.pitch}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a
          href="#contact"
          class="inline-flex h-10 items-center gap-2 rounded-md bg-brand-500 px-5 text-sm font-medium text-white hover:bg-brand-600"
        >
          Get in touch
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-4"
          >
            <path d="M5 12h14"></path>
            <path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="#experience"
          class="inline-flex h-10 items-center gap-2 rounded-md border border-cream-400 bg-white px-5 text-sm font-medium text-cream-900 hover:bg-cream-50 dark:border-white/15 dark:bg-transparent dark:text-white dark:hover:bg-white/5"
        >
          View experience
        </a>
      </div>

      <dl
        class="mt-12 grid max-w-3xl grid-cols-3 gap-6 border-t border-cream-300 pt-8 dark:border-white/10"
      >
        {
          profile.stats.map((stat) => (
            <div>
              <dt class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500">
                {stat.label}
              </dt>
              <dd class="mt-1 text-[1.625rem] font-normal leading-tight tracking-tight">
                {stat.value}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="md:col-span-5">
      <div
        class="relative h-full overflow-hidden rounded-xl border border-cream-300 bg-white dark:border-white/10 dark:bg-white/5"
      >
        <img
          src={profile.portrait}
          class="aspect-4/5 w-full object-cover md:aspect-auto md:h-full"
          alt={`${profile.name} portrait`}
        />
      </div>
    </div>
  </div>
</section>
