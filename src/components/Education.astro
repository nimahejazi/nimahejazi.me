---
import { profile } from "../data/profile";
---

<section class="border-b border-cream-300 py-20 dark:border-white/10">
  <div class="grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <span
        class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
        >03 · Education</span
      >
      <h2
        class="mt-3 text-3xl font-normal leading-tight tracking-tight md:text-4xl"
      >
        The foundation.
      </h2>
      <p class="mt-5 text-sm/relaxed text-cream-700 dark:text-cream-500">
        Computer science, with a continuous habit of relearning the basics.
      </p>
    </div>

    <ol class="divide-y divide-cream-300 lg:col-span-8 dark:divide-white/10">
      {
        profile.education.map((item) => (
          <li class="grid grid-cols-12 gap-4 py-5 first:pt-0">
            <div class="col-span-12 sm:col-span-3">
              <span class="font-mono text-xs text-cream-600 dark:text-cream-500">
                {item.period}
              </span>
            </div>
            <div class="col-span-12 sm:col-span-9">
              <h3 class="text-[1.375rem] font-normal leading-snug tracking-tight">
                {item.degree}
              </h3>
              <p class="mt-1 text-sm font-medium text-cream-700 dark:text-cream-500">
                {item.institution}
                {item.location && (
                  <span class="text-cream-600 dark:text-cream-500">
                    {" · "}{item.location}
                  </span>
                )}
              </p>
              {item.courses && item.courses.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2">
                  {item.courses.map((course) => (
                    <span class="rounded-full bg-cream-200/60 px-2.5 py-1 text-xs font-medium text-cream-700 dark:bg-white/10 dark:text-cream-300">
                      {course}
                    </span>
                  ))}
                </div>
              )}
              {item.certifications && item.certifications.length > 0 && (
                <ul class="mt-3 flex flex-wrap gap-x-4 gap-y-1 text-xs text-cream-600 dark:text-cream-500">
                  {item.certifications.map((cert) => (
                    <li>
                      <span class="font-medium text-cream-700 dark:text-cream-300">
                        {cert.name}
                      </span>{" "}
                      — {cert.issuer} ({cert.date})
                    </li>
                  ))}
                </ul>
              )}
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
