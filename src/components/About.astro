---
import { profile } from "../data/profile";

const groupTint: Record<string, string> = {
  "Analytics & Statistics": "bg-peach/25",
  "Engineering & Architecture": "bg-mint/25",
  "Data & AI": "bg-azure/25",
  "Business & Communication": "bg-lavender/25",
};
---

<section
  id="about"
  class="border-b border-cream-300 py-20 dark:border-white/10"
>
  <div class="grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <span
        class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
        >01 · About</span
      >
      <h2
        class="mt-3 text-3xl font-normal leading-tight tracking-tight md:text-4xl"
      >
        Calm code, clear systems.
      </h2>
      <p class="mt-5 text-sm/relaxed text-cream-700 dark:text-cream-500">
        {profile.about}
      </p>
    </div>

    <div class="min-w-0 lg:col-span-8">
      <div
        class="overflow-hidden rounded-xl border border-cream-300 bg-white dark:border-white/10 dark:bg-white/5"
      >
        <div
          class="flex items-center gap-2 border-b border-cream-300 px-4 py-3 dark:border-white/10"
        >
          <span class="size-2.5 rounded-full bg-peach"></span>
          <span class="size-2.5 rounded-full bg-gold"></span>
          <span class="size-2.5 rounded-full bg-mint"></span>
          <span
            class="ml-3 font-mono text-xs text-cream-600 dark:text-cream-500"
            >~/about/stack.ts</span
          >
        </div>
        <pre
          class="overflow-x-auto px-5 py-5 font-mono text-[13px] leading-relaxed text-cream-900 dark:text-cream-200"
        ><span class="text-cream-600 dark:text-cream-500">// stack</span>
<span class="text-gold">const</span> stack = {`{`}
  languages: [{profile.stack.languages.map((l) => `"${l}"`).join(", ")}],
  frontend:  [{profile.stack.frontend.map((l) => `"${l}"`).join(", ")}],
  backend:   [{profile.stack.backend.map((l) => `"${l}"`).join(", ")}],
  tooling:   [{profile.stack.tooling.map((l) => `"${l}"`).join(", ")}],
{`}`};</pre>
      </div>

      <div class="mt-4 space-y-4">
        {
          profile.skills.map((group) => (
            <div>
              <h3 class="mb-2 text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500">
                {group.category}
              </h3>
              <div class="flex flex-wrap gap-2">
                {group.items.map((skill) => (
                  <span class={`inline-flex items-center gap-1.5 rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-tight text-cream-900 dark:text-cream-100 ${groupTint[group.category] ?? "bg-cream-300/25"}`}>
                    {skill}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
