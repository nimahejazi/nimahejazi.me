# Public environment variables

# Privacy-friendly analytics (Plausible or Umami). Leave unset to disable.
# Plausible example:
# PUBLIC_ANALYTICS_SRC=https://plausible.io/js/script.js
# PUBLIC_ANALYTICS_DOMAIN=nimahejazi.me
# Umami example:
# PUBLIC_ANALYTICS_SRC=https://umami.example.com/script.js
# PUBLIC_ANALYTICS_DOMAIN=<umami-website-id>
PUBLIC_ANALYTICS_SRC=
PUBLIC_ANALYTICS_DOMAIN=
