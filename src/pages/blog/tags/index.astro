---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import "../../../styles/global.css";

const posts = await getCollection("blog");
const counts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    counts.set(tag, (counts.get(tag) ?? 0) + 1);
  }
}
const tags = [...counts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags" description="Browse blog posts by tag.">
  <Header />
  <main class="mx-auto max-w-6xl px-5 py-20 lg:px-10">
    <span
      class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
      >Tags</span
    >
    <h1 class="mt-3 text-4xl font-normal leading-tight tracking-tight md:text-5xl">
      Topics.
    </h1>
    <ul class="mt-10 flex flex-wrap gap-3">
      {
        tags.map(([tag, count]) => (
          <li>
            <a
              href={`/blog/tags/${tag}/`}
              class="inline-flex items-center gap-2 rounded-full bg-cream-200/60 px-4 py-2 text-sm font-medium text-cream-800 hover:bg-cream-300/60 dark:bg-white/10 dark:text-cream-200 dark:hover:bg-white/20"
            >
              {tag}
              <span class="font-mono text-xs text-cream-600 dark:text-cream-400">
                {count}
              </span>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
