---
import { profile } from "../data/profile";

const year = new Date().getFullYear();
---

<footer class="border-t border-cream-300 dark:border-white/10">
  <div
    class="mx-auto flex max-w-6xl flex-col items-start justify-between gap-3 px-5 py-8 text-sm text-cream-700 sm:flex-row sm:items-center lg:px-10 dark:text-cream-500"
  >
    <p>
      &copy; {year} · {profile.name}
    </p>
    <p>
      Crafted with care · by {profile.wordmark}
    </p>
  </div>
</footer>
