---
import { profile } from "../data/profile";
---

<section
  id="experience"
  class="border-b border-cream-300 py-20 dark:border-white/10"
>
  <div class="grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <span
        class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
        >02 · Experience</span
      >
      <h2
        class="mt-3 text-3xl font-normal leading-tight tracking-tight md:text-4xl"
      >
        A practiced hand.
      </h2>
      <p class="mt-5 text-sm/relaxed text-cream-700 dark:text-cream-500">
        A track record of shipping real systems across teams and domains.
      </p>
    </div>

    <ul class="space-y-3 lg:col-span-8">
      {
        profile.experience.map((item) => (
          <li class="rounded-xl border border-cream-300 bg-white p-6 dark:border-white/10 dark:bg-white/5">
            <div class="flex flex-wrap items-baseline justify-between gap-3">
              <h3 class="text-[1.375rem] font-normal leading-snug tracking-tight">
                {item.title}
              </h3>
              <span class="font-mono text-xs text-cream-600 dark:text-cream-500">
                {item.period}
              </span>
            </div>
            <p class="mt-1 text-sm font-medium text-brand-500">{item.company}</p>
            <p class="mt-3 text-sm/relaxed text-cream-700 dark:text-cream-500">
              {item.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
