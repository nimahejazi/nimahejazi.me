---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import "../../../styles/global.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  const tags = new Set<string>();
  for (const post of posts) {
    for (const tag of post.data.tags) tags.add(tag);
  }
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()),
    },
  }));
}

const { tag, posts } = Astro.props;
---

<BaseLayout title={`${tag} · tags`} description={`Posts tagged ${tag}.`}>
  <Header />
  <main class="mx-auto max-w-6xl px-5 py-20 lg:px-10">
    <a
      href="/blog/tags"
      class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
      >← All tags</a
    >
    <h1 class="mt-3 text-4xl font-normal leading-tight tracking-tight md:text-5xl">
      <span class="text-brand-500">#</span>{tag}
    </h1>
    <ul class="mt-10 grid gap-4">
      {
        posts.map((post) => (
          <li>
            <a
              href={`/blog/${post.id}/`}
              class="group block rounded-xl border border-cream-300 bg-white p-6 transition hover:bg-cream-50 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              <div class="flex flex-wrap items-baseline justify-between gap-3">
                <h2 class="text-[1.375rem] font-normal leading-snug tracking-tight group-hover:text-brand-600">
                  {post.data.title}
                </h2>
                <time class="font-mono text-xs text-cream-600 dark:text-cream-500">
                  {post.data.date.toISOString().slice(0, 10)}
                </time>
              </div>
              <p class="mt-3 text-sm/relaxed text-cream-700 dark:text-cream-500">
                {post.data.excerpt}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
