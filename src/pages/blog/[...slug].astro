---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import "../../styles/global.css";
import "katex/dist/katex.min.css";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <Header />
  <main class="mx-auto max-w-3xl px-5 py-20 lg:px-10">
    <a
      href="/blog"
      class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
      >← Back to blog</a
    >
    <article class="mt-8">
      <header>
        <div class="flex flex-wrap items-baseline gap-3">
          <h1 class="text-4xl font-normal leading-tight tracking-tight md:text-5xl">
            {post.data.title}
          </h1>
        </div>
        <time
          class="mt-3 block font-mono text-xs text-cream-600 dark:text-cream-500"
          >{post.data.date.toISOString().slice(0, 10)}</time
        >
        {
          post.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-cream-200/60 px-2.5 py-1 text-xs font-medium text-cream-700 dark:bg-white/10 dark:text-cream-300">
                  {tag}
                </span>
              ))}
            </div>
          )
        }
      </header>

      <div
        class="prose-custom mt-10 text-cream-800 dark:text-cream-200 [&_pre]:rounded-xl [&_pre]:border [&_pre]:border-cream-300 [&_pre]:bg-white [&_pre]:p-4 dark:[&_pre]:border-white/10 dark:[&_pre]:bg-white/5 [&_code]:font-mono [&_.katex-display]:my-6 [&_p]:leading-relaxed [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-normal [&_h2]:tracking-tight"
      >
        <Content />
      </div>
    </article>
  </main>
</BaseLayout>
