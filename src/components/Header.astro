---
import { profile } from "../data/profile";
import DarkModeToggle from "./DarkModeToggle.astro";
---

<header class="border-b border-cream-300 dark:border-white/10">
  <div
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 lg:px-10"
  >
    <a
      href="/"
      class="inline-flex items-baseline gap-1 font-medium tracking-tight"
    >
      {profile.wordmark}
    </a>

    <div class="flex items-center gap-2 sm:gap-5">
      <nav class="hidden items-center gap-6 md:flex">
        <a
          href="/blog"
          class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
          >Blog</a
        >
        <a
          href="/#about"
          class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
          >About</a
        >
        <a
          href="/#experience"
          class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
          >Experience</a
        >
        <a
          href="/#projects"
          class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
          >Projects</a
        >
        <a
          href="/#contact"
          class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
          >Contact</a
        >
      </nav>

      <DarkModeToggle />

      <button
        id="menu-toggle"
        type="button"
        class="inline-flex size-9 items-center justify-center rounded-md text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white md:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-5"
        >
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="overflow-hidden transition-all duration-300 ease-out md:hidden"
  >
    <nav
      class="mx-auto flex max-w-6xl flex-col gap-1 border-t border-cream-300 px-5 py-3 lg:px-10 dark:border-white/10"
    >
      <a
        href="/blog"
        class="rounded-md px-2 py-2 text-sm font-medium text-cream-700 hover:bg-cream-200/60 hover:text-cream-900 dark:text-cream-500 dark:hover:bg-white/10 dark:hover:text-white"
        >Blog</a
      >
      <a
        href="/#about"
        class="rounded-md px-2 py-2 text-sm font-medium text-cream-700 hover:bg-cream-200/60 hover:text-cream-900 dark:text-cream-500 dark:hover:bg-white/10 dark:hover:text-white"
        >About</a
      >
      <a
        href="/#experience"
        class="rounded-md px-2 py-2 text-sm font-medium text-cream-700 hover:bg-cream-200/60 hover:text-cream-900 dark:text-cream-500 dark:hover:bg-white/10 dark:hover:text-white"
        >Experience</a
      >
      <a
        href="/#projects"
        class="rounded-md px-2 py-2 text-sm font-medium text-cream-700 hover:bg-cream-200/60 hover:text-cream-900 dark:text-cream-500 dark:hover:bg-white/10 dark:hover:text-white"
        >Projects</a
      >
      <a
        href="/#contact"
        class="rounded-md px-2 py-2 text-sm font-medium text-cream-700 hover:bg-cream-200/60 hover:text-cream-900 dark:text-cream-500 dark:hover:bg-white/10 dark:hover:text-white"
        >Contact</a
      >
    </nav>
  </div>
</header>

<style>
  :global(#mobile-menu) {
    max-height: 0;
    opacity: 0;
  }
  :global(#mobile-menu.is-open) {
    max-height: 20rem;
    opacity: 1;
  }
</style>

<script>
  const toggle = document.getElementById("menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const setOpen = (open) => {
    menu?.classList.toggle("is-open", open);
    toggle?.setAttribute("aria-expanded", String(open));
    if (menu) menu.inert = !open;
  };
  toggle?.addEventListener("click", () =>
    setOpen(!menu?.classList.contains("is-open")),
  );
  menu
    ?.querySelectorAll("a")
    .forEach((link) => link.addEventListener("click", () => setOpen(false)));
</script>
