---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
import "katex/dist/katex.min.css";

interface Props {
  title: string;
  description?: string;
  ogType?: "website" | "article";
  backHref: string;
  backLabel: string;
}

const { title, description, ogType = "article", backHref, backLabel } =
  Astro.props;
---

<BaseLayout title={title} description={description} ogType={ogType}>
  <Header />
  <main class="mx-auto max-w-3xl px-5 py-20 lg:px-10">
    <a
      href={backHref}
      class="text-sm font-medium text-cream-700 hover:text-cream-900 dark:text-cream-500 dark:hover:text-white"
      >{backLabel}</a
    >
    <article class="mt-8">
      <header>
        <slot name="header" />
      </header>

      <div
        class="prose-custom mt-10 text-cream-800 dark:text-cream-200 [&_pre]:rounded-xl [&_pre]:border [&_pre]:border-cream-300 [&_pre]:bg-white [&_pre]:p-4 dark:[&_pre]:border-white/10 dark:[&_pre]:bg-white/5 [&_code]:font-mono [&_.katex-display]:my-6 [&_p]:leading-relaxed [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-normal [&_h2]:tracking-tight"
      >
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>
