---
interface Props {
  project: import("../data/profile").ProjectItem;
  index: number;
}

const { project, index } = Astro.props;
---

<article
  class="group flex flex-col rounded-xl border border-cream-300 bg-white p-6 dark:border-white/10 dark:bg-white/5"
>
  <div class="flex items-center justify-between">
    <span
      class="inline-flex items-center gap-1.5 rounded-full bg-lavender/25 px-2.5 py-1 text-xs font-semibold uppercase tracking-tight text-cream-900 dark:text-cream-100"
    >
      {project.tags.join(" · ")}
    </span>
    <span class="font-mono text-xs text-cream-600 dark:text-cream-500">
      {String(index + 1).padStart(2, "0")}
    </span>
  </div>
  <h3 class="mt-5 text-[1.375rem] font-normal leading-snug tracking-tight">
    {project.title}
  </h3>
  <p class="mt-3 flex-1 text-sm/relaxed text-cream-700 dark:text-cream-500">
    {project.description}
  </p>
  {
    project.href && (
      <a
        href={project.href}
        class="mt-5 inline-flex items-center gap-2 font-mono text-xs text-cream-900 underline decoration-cream-400 underline-offset-4 hover:decoration-cream-900 dark:text-white dark:decoration-white/30 dark:hover:decoration-white"
      >
        {project.href.replace(/^https?:\/\//, "")}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-3.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
        >
          <path d="M7 7h10v10" />
          <path d="M7 17 17 7" />
        </svg>
      </a>
    )
  }
</article>
