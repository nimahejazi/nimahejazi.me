---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import "../../styles/global.css";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="Blog" description="Writing on engineering, math, and code.">
  <Header />
  <main class="mx-auto max-w-6xl px-5 py-20 lg:px-10">
    <span
      class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
      >Blog</span
    >
    <h1 class="mt-3 text-4xl font-normal leading-tight tracking-tight md:text-5xl">
      Writing.
    </h1>
    <ul class="mt-10 grid gap-4">
      {
        posts.map((post) => (
          <li>
            <div
              class="group relative block rounded-xl border border-cream-300 bg-white p-6 transition hover:bg-cream-50 dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
            >
              <div class="flex flex-wrap items-baseline justify-between gap-3">
                <h2 class="text-[1.375rem] font-normal leading-snug tracking-tight group-hover:text-brand-600">
                  <a
                    href={`/blog/${post.id}/`}
                    class="after:absolute after:inset-0 after:content-['']"
                  >
                    {post.data.title}
                  </a>
                </h2>
                <time class="font-mono text-xs text-cream-600 dark:text-cream-500">
                  {post.data.date.toISOString().slice(0, 10)}
                </time>
              </div>
              <p class="mt-3 text-sm/relaxed text-cream-700 dark:text-cream-500">
                {post.data.excerpt}
              </p>
              {post.data.tags.length > 0 && (
                <div class="relative z-10 mt-4 flex flex-wrap gap-2">
                  {post.data.tags.map((tag) => (
                    <a
                      href={`/blog/tags/${tag}/`}
                      class="rounded-full bg-cream-200/60 px-2.5 py-1 text-xs font-medium text-cream-700 hover:bg-cream-300/60 dark:bg-white/10 dark:text-cream-300 dark:hover:bg-white/20"
                    >
                      {tag}
                    </a>
                  ))}
                </div>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </main>
</BaseLayout>
