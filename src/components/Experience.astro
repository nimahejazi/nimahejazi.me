---
import { profile } from "../data/profile";
---

<section
  id="experience"
  class="border-b border-cream-300 py-20 dark:border-white/10"
>
  <div class="grid gap-12 lg:grid-cols-12">
    <div class="lg:col-span-4">
      <span
        class="text-[11px] font-semibold uppercase tracking-[0.08em] text-cream-600 dark:text-cream-500"
        >02 · Experience</span
      >
      <h2
        class="mt-3 text-3xl font-normal leading-tight tracking-tight md:text-4xl"
      >
        A practiced hand.
      </h2>
      <p class="mt-5 text-sm/relaxed text-cream-700 dark:text-cream-500">
        A track record of shipping real systems across teams and domains.
      </p>
    </div>

      <ul class="space-y-3 lg:col-span-8">
        {
          profile.experience.map((item) => (
            <li class="rounded-xl border border-cream-300 bg-white p-6 dark:border-white/10 dark:bg-white/5">
              <div class="flex flex-wrap items-baseline justify-between gap-3">
                <h3 class="text-[1.375rem] font-normal leading-snug tracking-tight">
                  {item.title}
                </h3>
                <span class="font-mono text-xs text-cream-600 dark:text-cream-500">
                  {item.period}
                </span>
              </div>
              <p class="mt-1 text-sm font-medium text-brand-500">
                {item.company}
                {item.location && (
                  <span class="text-cream-600 dark:text-cream-500">
                    {" · "}{item.location}
                  </span>
                )}
              </p>
              <ul class="mt-3 grid list-disc grid-cols-1 gap-x-6 gap-y-1.5 pl-5 text-sm/relaxed text-cream-700 dark:text-cream-500 sm:grid-cols-2">
                {item.highlights.map((point) => (
                  <li>
                    {typeof point === "string" ? (
                      point
                    ) : (
                      <a
                        href={point.href}
                        class="underline decoration-cream-400 underline-offset-4 hover:decoration-cream-900 dark:decoration-white/30 dark:hover:decoration-white"
                      >
                        {point.text}
                      </a>
                    )}
                  </li>
                ))}
              </ul>
              {item.tags && item.tags.length > 0 && (
                <div class="mt-4 flex flex-wrap gap-2">
                  {item.tags.map((tag) => (
                    <span class="rounded-full bg-cream-200/60 px-2.5 py-1 text-xs font-medium text-cream-700 dark:bg-white/10 dark:text-cream-300">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </li>
          ))
        }
      </ul>
  </div>
</section>
